# Terraform working directories
.terraform/
.terraform.lock.hcl

# State files — never commit these
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Plan files (may contain sensitive values)
*.tfplan
*.plan

# Crash logs
crash.log
crash.*.log

# Override files (local-only customization)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated by 'terraform providers lock'
.terraform.lock.hcl

# Sensitive variable files — use environment variables or secrets manager instead
*.tfvars.local
secrets.tfvars

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo
